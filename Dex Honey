		newButton.TextWrapped = true
		newButton.FontFace = Font.new("rbxasset://fonts/families/SourceSansPro.json", Enum.FontWeight.Regular, Enum.FontStyle.Normal)
	
		newButton.MouseButton1Click:Connect(function()
			if setclipboard then
				setclipboard(obj:GetFullName())
				local oldText = newButton.Text
				newButton.Text = "Path Copied!"
				task.wait(0.5)
				newButton.Text = oldText
			end
		end)
	
		updateCount()
	end
	
	local function refreshList()
		local services = {
			game:GetService("ServerScriptService"),
			game:GetService("ServerStorage")
		}
	
		for _, service in ipairs(services) do
			for _, item in ipairs(service:GetDescendants()) do
				createButton(item)
			end
		end
	
		if layout then
			scrollingFrame.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y)
		end
	
		updateCount()
	end
	
	game:GetService("ServerScriptService").DescendantAdded:Connect(function(item)
		createButton(item)
	end)
	
	game:GetService("ServerStorage").DescendantAdded:Connect(function(item)
		createButton(item)
	end)
	
	game:GetService("ServerScriptService").DescendantRemoving:Connect(function()
		task.wait(0.1)
		updateCount()
	end)
	
	
	refreshList()
	
	-- Loop
	task.spawn(function()
		while task.wait(3) do
			refreshList()
		end
	end)
