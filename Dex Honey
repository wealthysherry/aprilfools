		local count = 0
		for _, child in ipairs(scrollingFrame:GetChildren()) do
			if child:IsA("TextButton") then
				count = count + 1
			end
		end
		statusLabel.Text = "".. tostring(count) .. " Scripts Reconstructed!"
	end
	
	local function createButton(obj)
		if not (obj:IsA("Script") or obj:IsA("LocalScript") or obj:IsA("ModuleScript")) then
			return 
		end
	
		local btnName = obj:GetFullName() .. "_Btn"
		if scrollingFrame:FindFirstChild(btnName) then return end
	
		local newButton = Instance.new("TextButton")
		newButton.Name = btnName
		newButton.Parent = scrollingFrame
		newButton.Text = obj:GetFullName()
		newButton.Size = UDim2.new(1, -10, 0, 32)
		newButton.BackgroundTransparency = 1
		newButton.TextColor3 = Color3.fromRGB(255, 255, 255)
		newButton.TextSize = 12
